{"featureSet":null,"errorCode":null,"notebookModels":null,"tools":null,"notebookModel":null,"knowledgeBase":null,"stackTrace":null,"notebookContent":"{\"sucess\":true,\"content\":{\"cells\":[{\"cell_type\":\"code\",\"metadata\":{\"id\":\"0_0.08869274247357217\"},\"execution_count\":0,\"source\":[\"    #sklearn train model\\n    import pandas\\n    from sklearn import model_selection\\n    from sklearn.linear_model import LogisticRegression\\n    from sklearn.naive_bayes import GaussianNB\\n    from sklearn.naive_bayes import MultinomialNB\\n    import pickle\\n    url = \\\"https://raw.githubusercontent.com/jbrownlee/Datasets/master/pima-indians-diabetes.data.csv\\\"\\n    names = ['preg', 'plas', 'pres', 'skin', 'test', 'mass', 'pedi', 'age', 'class']\\n    dataframe = pandas.read_csv(url, names=names)\\n    array = dataframe.values\\n    X = array[:,0:8]\\n    Y = array[:,8]\\n    test_size = 0.33\\n    seed = 7\\n    X_train, X_test, Y_train, Y_test = model_selection.train_test_split(X, Y, test_size=test_size, random_state=seed)\\n    model = MultinomialNB()\\n    model.fit(X_train, Y_train);\\n\"],\"outputs\":[]},{\"cell_type\":\"code\",\"metadata\":{\"id\":\"31117480344_0.7908342106360368\"},\"execution_count\":1,\"source\":[\"from bdbml import autolog_context, log_metric, log_param, save_model\\nfrom sklearn.metrics import accuracy_score, precision_score, recall_score, f1_score\\n\\n# predictions\\ny_pred = model.predict(X_test)\\n\\nwith autolog_context(\\n    model_name='versiontest4',\\n    experiment_name='diabetes_experiment',\\n    run_name='multinomial_nb_v1',\\n    tags={'model_type': 'ml', 'framework': 'sklearn'}\\n):\\n\\n    # ' log params\\n    for k, v in model.get_params().items():\\n        log_param(k, v)\\n\\n    # ' log metrics\\n    log_metric(\\\"accuracy\\\", accuracy_score(Y_test, y_pred))\\n    log_metric(\\\"precision\\\", precision_score(Y_test, y_pred))\\n    log_metric(\\\"recall\\\", recall_score(Y_test, y_pred))\\n    log_metric(\\\"f1_score\\\", f1_score(Y_test, y_pred))\\n\\n    # ' save model (FIXED)\\n    save_model(\\n        model,\\n        model_name='versiontest4',   # '' REQUIRED\\n        estimator_type='classification',\\n        X_train=X_train,\\n        y_train=Y_train\\n    )\"],\"outputs\":[]},{\"cell_type\":\"code\",\"metadata\":{\"id\":\"31117480344_0.6126007027367615\"},\"execution_count\":2,\"source\":[\"from bdbml import autolog, autolog_context, log_metric, log_param, save_model \\nwith autolog_context(model_name='versiontest4.dill',experiment_name='sklearn',run_name='',tags={'model_type':'ml', 'framework': ''}) as run:\\n    saved_model = run.save_model(model, estimator_type='classification', model_id=31119215447, X_train= None ,y_train= None)\"],\"outputs\":[{\"name\":\"stdout\",\"text\":\"WARN: Training data is not provided. Unable to generate Explainer Dashboard\\n\",\"output_type\":\"stream\"}]},{\"cell_type\":\"code\",\"metadata\":{\"id\":\"31117480344_0.9839322500401455\"},\"execution_count\":null,\"source\":[\"print(\\\"v2\\\")\"],\"outputs\":[]}],\"metadata\":{},\"nbformat\":4,\"nbformat_minor\":2}}","autoMLs":null,"scripts":null,"notebook":{"mongoQL":null,"updatedBy":261189782,"data":"{\"datasets\":[],\"uncheckeddatasets\":[],\"code\":[{\"id\":\"0_0.08869274247357217\",\"code\":\"    #sklearn train model\\n    import pandas\\n    from sklearn import model_selection\\n    from sklearn.linear_model import LogisticRegression\\n    from sklearn.naive_bayes import GaussianNB\\n    from sklearn.naive_bayes import MultinomialNB\\n    import pickle\\n    url = \\\"https://raw.githubusercontent.com/jbrownlee/Datasets/master/pima-indians-diabetes.data.csv\\\"\\n    names = ['preg', 'plas', 'pres', 'skin', 'test', 'mass', 'pedi', 'age', 'class']\\n    dataframe = pandas.read_csv(url, names=names)\\n    array = dataframe.values\\n    X = array[:,0:8]\\n    Y = array[:,8]\\n    test_size = 0.33\\n    seed = 7\\n    X_train, X_test, Y_train, Y_test = model_selection.train_test_split(X, Y, test_size=test_size, random_state=seed)\\n    model = MultinomialNB()\\n    model.fit(X_train, Y_train);\\n\",\"count\":1,\"mode\":\"preview\",\"type\":\"code\",\"hover\":true,\"interrupt\":false,\"warning\":false,\"outputArray\":[],\"lineNumber\":false,\"laodmodel\":false,\"pre_cell_id\":0,\"is_pre_cell\":false,\"succORerr\":true,\"expand\":false,\"outputexpand\":false,\"readonly\":false,\"markDowns\":false,\"loader\":false,\"cellType\":\"code\",\"image\":\"\",\"error\":\"\",\"result\":\"\",\"algorithms\":\"\",\"semicolon\":\"\",\"cputimes\":\"\",\"showcputime\":false,\"secret\":[]},{\"id\":\"31117480344_0.7908342106360368\",\"code\":\"from bdbml import autolog_context, log_metric, log_param, save_model\\nfrom sklearn.metrics import accuracy_score, precision_score, recall_score, f1_score\\n\\n# predictions\\ny_pred = model.predict(X_test)\\n\\nwith autolog_context(\\n    model_name='versiontest4',\\n    experiment_name='diabetes_experiment',\\n    run_name='multinomial_nb_v1',\\n    tags={'model_type': 'ml', 'framework': 'sklearn'}\\n):\\n\\n    # ' log params\\n    for k, v in model.get_params().items():\\n        log_param(k, v)\\n\\n    # ' log metrics\\n    log_metric(\\\"accuracy\\\", accuracy_score(Y_test, y_pred))\\n    log_metric(\\\"precision\\\", precision_score(Y_test, y_pred))\\n    log_metric(\\\"recall\\\", recall_score(Y_test, y_pred))\\n    log_metric(\\\"f1_score\\\", f1_score(Y_test, y_pred))\\n\\n    # ' save model (FIXED)\\n    save_model(\\n        model,\\n        model_name='versiontest4',   # '' REQUIRED\\n        estimator_type='classification',\\n        X_train=X_train,\\n        y_train=Y_train\\n    )\",\"count\":1,\"mode\":\"preview\",\"type\":\"code\",\"hover\":true,\"interrupt\":false,\"warning\":false,\"outputArray\":[],\"lineNumber\":false,\"laodmodel\":false,\"pre_cell_id\":0,\"is_pre_cell\":false,\"succORerr\":true,\"expand\":false,\"outputexpand\":false,\"readonly\":false,\"markDowns\":false,\"loader\":false,\"ce